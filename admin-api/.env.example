NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=changeme
DB_NAME=ecommerce
DB_SSL=false

JWT_SECRET=change-this-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_COOKIE_NAME=refresh_token
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAME_SITE=lax
JWT_REFRESH_FINGERPRINT_SALT=change-this-fingerprint-salt
SEED_API_ENABLED=true
SEED_API_CONFIRMATION_PHRASE=CONFIRMAR
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
APP_URL=http://localhost:5173
MAIL_PROVIDER=noop
MAIL_FROM=Ecommerce <onboarding@resend.dev>
RESEND_API_KEY=
SEED_SUPER_ADMIN_EMAIL=superadmin@local.dev
SEED_SUPER_ADMIN_PASSWORD=SuperAdmin2026!
SEED_ADMIN_EMAIL=admin@local.dev
SEED_ADMIN_PASSWORD=Admin2026!
