{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Entregamos tu pedido</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Tu envio de la orden <strong>#{{orderCode}}</strong> fue entregado.
    {{#if deliveredAt}}Fecha de entrega: <strong>{{formatDate deliveredAt}}</strong>.{{/if}}
  </p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Esperamos que disfrutes tu compra. Tu opinion nos ayuda a mejorar:
  </p>
  {{> button url=reviewUrl label="Dejar una resena" color="#16a34a" }}
{{/layout}}
