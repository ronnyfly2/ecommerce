{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Tu devolucion fue aprobada</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Aprobamos la devolucion <strong>#{{returnCode}}</strong>.
    {{#if instructions}}Por favor sigue estas indicaciones:{{/if}}
  </p>
  {{#if instructions}}
    <div style="background:#f9fafb;border-radius:8px;padding:16px;margin:16px 0;font-size:14px;line-height:1.6;">
      {{instructions}}
    </div>
  {{/if}}
  {{> button url=returnUrl label="Ver detalle" color="#16a34a" }}
{{/layout}}
