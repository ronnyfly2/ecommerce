{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Tu pedido esta en camino</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    El envio {{#if trackingNumber}}<strong>{{trackingNumber}}</strong>{{/if}} de tu orden
    <strong>#{{orderCode}}</strong> esta en transito.
  </p>
  {{#if estimatedDelivery}}
    <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
      Entrega estimada: <strong>{{formatDate estimatedDelivery}}</strong>
    </p>
  {{/if}}
  {{#if trackingUrl}}
    {{> button url=trackingUrl label="Rastrear envio" }}
  {{/if}}
{{/layout}}
