{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">No pudimos validar tu pago</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Revisamos el comprobante de tu orden <strong>#{{orderCode}}</strong> y no pudimos validarlo.
  </p>
  {{#if reason}}
    <p style="margin:0 0 12px;font-size:14px;line-height:1.6;background:#fef2f2;border-left:3px solid #dc2626;padding:12px 16px;">
      <strong>Motivo:</strong> {{reason}}
    </p>
  {{/if}}
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Puedes volver a subir un comprobante desde tu orden.
  </p>
  {{> button url=orderUrl label="Subir nuevo comprobante" color="#dc2626" }}
{{/layout}}
