{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Actualizacion de tu orden</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    El estado de tu orden <strong>#{{orderCode}}</strong> cambio de
    <strong>{{previousStatus}}</strong> a <strong>{{status}}</strong>.
  </p>
  {{> button url=orderUrl label="Ver detalle" }}
{{/layout}}
