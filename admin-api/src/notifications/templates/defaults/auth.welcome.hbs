{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Bienvenido a {{appName}}</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Tu cuenta fue creada correctamente. Desde tu panel podras ver tus ordenes, envios y
    preferencias.
  </p>
  {{> button url=appUrl label="Ir al panel" color="#16a34a" }}
{{/layout}}
