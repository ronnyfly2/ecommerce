{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Tu orden fue recibida</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Recibimos tu orden <strong>#{{orderCode}}</strong> y ya la estamos procesando.
  </p>
  {{> items-table items=items total=total currency=currency }}
  {{> button url=orderUrl label="Ver mi orden" }}
  <p style="margin:24px 0 0;font-size:13px;color:#6b7280;line-height:1.6;">
    Si tienes alguna consulta, responde a este correo y nuestro equipo te ayudara.
  </p>
{{/layout}}
