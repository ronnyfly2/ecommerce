{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">No pudimos aprobar tu devolucion</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Revisamos tu solicitud <strong>#{{returnCode}}</strong> y no pudimos aprobarla.
  </p>
  {{#if reason}}
    <p style="margin:0 0 12px;font-size:14px;line-height:1.6;background:#fef2f2;border-left:3px solid #dc2626;padding:12px 16px;">
      <strong>Motivo:</strong> {{reason}}
    </p>
  {{/if}}
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Si crees que es un error, responde este correo y nuestro equipo revisara tu caso.
  </p>
  {{> button url=returnUrl label="Ver detalle" color="#dc2626" }}
{{/layout}}
