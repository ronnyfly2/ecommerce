{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Alerta de stock bajo</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{recipientName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Los siguientes productos alcanzaron el umbral configurado y necesitan reposicion:
  </p>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse:collapse;margin:16px 0;">
    <thead>
      <tr>
        <th align="left" style="padding:8px 0;border-bottom:1px solid #e5e7eb;font-size:12px;color:#6b7280;text-transform:uppercase;">Producto</th>
        <th align="left" style="padding:8px 0;border-bottom:1px solid #e5e7eb;font-size:12px;color:#6b7280;text-transform:uppercase;">SKU</th>
        <th align="center" style="padding:8px 0;border-bottom:1px solid #e5e7eb;font-size:12px;color:#6b7280;text-transform:uppercase;">Stock</th>
        <th align="center" style="padding:8px 0;border-bottom:1px solid #e5e7eb;font-size:12px;color:#6b7280;text-transform:uppercase;">Umbral</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
        <tr>
          <td style="padding:10px 0;border-bottom:1px solid #f3f4f6;font-size:14px;">{{name}}{{#if store}} <span style="color:#6b7280;font-size:12px;">({{store}})</span>{{/if}}</td>
          <td style="padding:10px 0;border-bottom:1px solid #f3f4f6;font-size:13px;color:#6b7280;">{{sku}}</td>
          <td align="center" style="padding:10px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#b45309;font-weight:600;">{{stock}}</td>
          <td align="center" style="padding:10px 0;border-bottom:1px solid #f3f4f6;font-size:14px;color:#6b7280;">{{threshold}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
  {{> button url=inventoryUrl label="Ir al inventario" color="#b45309" }}
{{/layout}}
