{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Recupera tu contrasena</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Recibimos una solicitud para restablecer tu contrasena. Si no fuiste tu, puedes ignorar este
    correo y tu contrasena seguira igual.
  </p>
  {{> button url=resetUrl label="Restablecer contrasena" }}
  <p style="margin:24px 0 4px;font-size:12px;color:#6b7280;">O copia este enlace en tu navegador:</p>
  <p style="margin:0;font-size:12px;color:#6b7280;word-break:break-all;">{{resetUrl}}</p>
  <p style="margin:16px 0 0;font-size:12px;color:#6b7280;">Este enlace vence en {{expiresIn}}.</p>
{{/layout}}
