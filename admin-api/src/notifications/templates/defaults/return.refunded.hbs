{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Emitimos tu reembolso</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Emitimos el reembolso de tu devolucion <strong>#{{returnCode}}</strong> por
    <strong>{{formatCurrency refundAmount currency}}</strong>.
    {{#if refundMethod}}Metodo: <strong>{{refundMethod}}</strong>.{{/if}}
  </p>
  <p style="margin:0 0 12px;font-size:13px;line-height:1.6;color:#6b7280;">
    Segun tu banco, el credito puede tardar entre 3 y 10 dias habiles en reflejarse.
  </p>
  {{> button url=returnUrl label="Ver comprobante" color="#16a34a" }}
{{/layout}}
