{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Recibimos tu comprobante</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Recibimos el comprobante de tu orden <strong>#{{orderCode}}</strong>. Nuestro equipo lo validara
    en las proximas horas y te avisara por correo cuando el pago sea aprobado.
  </p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Total: <strong>{{formatCurrency total currency}}</strong>
  </p>
  {{> button url=orderUrl label="Ver mi orden" }}
{{/layout}}
