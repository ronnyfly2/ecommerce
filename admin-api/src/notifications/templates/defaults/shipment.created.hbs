{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Tu envio fue registrado</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Registramos un envio para tu orden <strong>#{{orderCode}}</strong>.
  </p>
  <div style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:8px;padding:16px;margin:16px 0;">
    {{#if carrier}}<p style="margin:0 0 4px;font-size:13px;"><strong>Transportadora:</strong> {{carrier}}</p>{{/if}}
    {{#if trackingNumber}}<p style="margin:0 0 4px;font-size:13px;"><strong>Codigo de rastreo:</strong> {{trackingNumber}}</p>{{/if}}
    {{#if estimatedDelivery}}<p style="margin:0;font-size:13px;"><strong>Entrega estimada:</strong> {{formatDate estimatedDelivery}}</p>{{/if}}
  </div>
  {{#if trackingUrl}}
    {{> button url=trackingUrl label="Rastrear envio" }}
  {{else}}
    {{> button url=orderUrl label="Ver mi orden" }}
  {{/if}}
{{/layout}}
