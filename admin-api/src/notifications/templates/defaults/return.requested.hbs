{{#> layout }}
  <h2 style="margin:0 0 16px;font-size:22px;">Recibimos tu solicitud de devolucion</h2>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">Hola {{customerName}},</p>
  <p style="margin:0 0 12px;font-size:14px;line-height:1.6;">
    Registramos tu solicitud <strong>#{{returnCode}}</strong> para la orden
    <strong>#{{orderCode}}</strong>. La revisaremos y te avisaremos la decision pronto.
  </p>
  {{#if reason}}
    <p style="margin:0 0 12px;font-size:14px;line-height:1.6;background:#f9fafb;border-left:3px solid #6b7280;padding:12px 16px;">
      <strong>Motivo:</strong> {{reason}}
    </p>
  {{/if}}
  {{> button url=returnUrl label="Ver mi solicitud" }}
{{/layout}}
